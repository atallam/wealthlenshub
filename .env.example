# ─────────────────────────────────────────────────────────────────────────────
# WealthLens Hub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Your project URL and service-role key from Supabase → Settings → API.
# The service key bypasses RLS — keep it server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Supabase (Vite / frontend) ────────────────────────────────────────────────
# Anon key — safe to expose in the browser (RLS enforces access control).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Anthropic (REQUIRED for AI features) ─────────────────────────────────────
# Used for AI Advisor chat, portfolio brief, concall analysis, etc.
# https://console.anthropic.com/keys
ANTHROPIC_KEY=sk-ant-...

# ── Encryption key (REQUIRED in production) ───────────────────────────────────
# 64-character hex string (32 bytes) used to encrypt PAN, Plaid tokens, and
# budget transaction descriptions with AES-256-GCM.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this key makes ALL previously encrypted data unreadable.
BUDGET_ENCRYPT_KEY=your-64-char-hex-key-here

# ── Resend (email alerts & digests) ──────────────────────────────────────────
# Required for FD expiry alerts, portfolio alert digests, stale-holding nudges.
# https://resend.com — free tier: 100 emails/day
RESEND_API_KEY=re_...
RESEND_FROM=WealthLens Hub <alerts@yourdomain.com>

# ── App URL ───────────────────────────────────────────────────────────────────
# Base URL of the deployed app — used in email CTAs.
APP_URL=https://app.wealthlenshub.com

# ── Cron secret ───────────────────────────────────────────────────────────────
# Passed as x-cron-secret header to protect /api/cron/* endpoints.
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ── Twelve Data (live stock & ETF prices) ─────────────────────────────────────
# https://twelvedata.com — free tier: 800 API credits/day
# Falls back to Yahoo Finance scraping if not set.
TWELVE_DATA_KEY=your-twelve-data-api-key

# ── SnapTrade (US brokerage sync — optional) ──────────────────────────────────
# Enables Robinhood / Schwab / IBKR account linking.
# https://snaptrade.com/dashboard
SNAPTRADE_CLIENT_ID=your-snaptrade-client-id
SNAPTRADE_CONSUMER_KEY=your-snaptrade-consumer-key

# ── Plaid (US bank transactions — optional) ───────────────────────────────────
# https://dashboard.plaid.com — use sandbox env for testing
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox   # sandbox | development | production

# ── Gmail (CAS email auto-import — optional) ──────────────────────────────────
# OAuth2 credentials for reading CAS statement emails from Gmail.
# Create credentials at https://console.cloud.google.com → APIs → OAuth 2.0
GMAIL_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REDIRECT_URI=https://app.wealthlenshub.com/api/gmail/callback
GMAIL_STATE_SECRET=your-gmail-state-secret   # random string for CSRF protection

# ── Setu AA (Account Aggregator — optional) ───────────────────────────────────
# Indian Account Aggregator framework for bank/demat data.
# https://setu.co/data/account-aggregator
SETU_ENABLED=false
SETU_BASE_URL=https://fiu-sandbox.setu.co
SETU_CLIENT_ID=your-setu-client-id
SETU_CLIENT_SECRET=your-setu-client-secret
SETU_PRODUCT_INSTANCE_ID=your-setu-product-instance-id
SETU_WEBHOOK_SECRET=your-setu-webhook-secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development   # development | production

# CORS_ORIGINS — comma-separated allowed origins (defaults to APP_URL in production)
# CORS_ORIGINS=https://app.wealthlenshub.com,https://wealthlenshub.com

# ── FD model override (optional) ─────────────────────────────────────────────
# Anthropic model for FD analysis (defaults to claude-haiku-4-5-20251001).
# FD_MODEL=claude-haiku-4-5-20251001
